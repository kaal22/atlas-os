# Build trees (regenerated by live-build)
build/
chroot/
binary/
.build/
cache/
build-cache/**
!build-cache/.gitkeep
!build-cache/**/.gitkeep

# Live-build transient artefacts at repo root
binary.modified_timestamps
chroot.files
chroot.packages.*
live-image-*.contents
live-image-*.files
live-image-*.packages
*.log

# Large binary products — tracked selectively under dist/ via Git LFS
*.img
*.img.zst
*.qcow2
*.deb
!packages/**/debian/

# dist/: checksums + placeholder. Do NOT commit the hybrid ISO to git —
# it is ~2.6GiB (GitHub max file 100MiB; Releases max 2GiB; free LFS 1GiB).
dist/*
!dist/.gitkeep
!dist/*.sha256
!dist/*.sha512
!dist/*.iso.sha256
!dist/*.iso.sha512

# Secrets / env
release/keys/dev/*.key
release/keys/dev/*.pem
!release/keys/dev/*.pub
!release/keys/dev/*.gpg.pub
.env
.venv/
node_modules/
packages/*/node_modules/
packages/*/dist/
packages/*/build/
__pycache__/
*.pyc
.DS_Store

# Test evidence
tests/installer/evidence/*
!tests/installer/evidence/.gitkeep

# live-build auto-copied stock hooks (recreated by lb config); keep Atlas hooks
config/hooks/normal/1000-*.hook.chroot
config/hooks/normal/1010-*.hook.chroot
config/hooks/normal/1020-*.hook.chroot
config/hooks/normal/5000-*.hook.chroot
config/hooks/normal/5010-*.hook.chroot
config/hooks/normal/5020-*.hook.chroot
config/hooks/normal/5030-*.hook.chroot
config/hooks/normal/5040-*.hook.chroot
config/hooks/normal/5050-*.hook.chroot
config/hooks/normal/8000-*.hook.chroot
config/hooks/normal/8010-*.hook.chroot
config/hooks/normal/8020-*.hook.chroot
config/hooks/normal/8030-*.hook.chroot
config/hooks/normal/8040-*.hook.chroot
config/hooks/normal/8050-*.hook.chroot
config/hooks/normal/8060-*.hook.chroot
config/hooks/normal/8070-*.hook.chroot
config/hooks/normal/8080-*.hook.chroot
config/hooks/normal/8090-*.hook.chroot
config/hooks/normal/8100-*.hook.chroot
config/hooks/normal/8110-*.hook.chroot
config/hooks/normal/9000-remove-*.hook.chroot
config/hooks/normal/9010-remove-*.hook.chroot
config/hooks/normal/9020-remove-*.hook.chroot
config/hooks/live/0010-*.hook.chroot
config/hooks/live/0050-*.hook.chroot

# live-build generated config snapshots (from lb config)
config/binary
config/bootstrap
config/chroot
config/common
config/source
config/package-lists/live.list.chroot

# Offline payloads / host binaries staged into includes (built by lock-refresh / export)
config/includes.chroot/usr/share/atlas/payload/*.tar.zst
config/includes.chroot/usr/bin/ollama
dist/atlas-core-oci-payload.tar.zst
