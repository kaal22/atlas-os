[Unit]
Description=Atlas OS first-boot provisioning
After=local-fs.target network-online.target docker.service
Wants=docker.service
ConditionPathExists=/etc/atlas/firstboot-pending
# Never run during live installer session (same squashfs as install).
ConditionKernelCommandLine=!boot=live

[Service]
Type=oneshot
ExecStart=/usr/lib/atlas/atlas-firstboot.sh
RemainAfterExit=yes
TimeoutStartSec=0
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
