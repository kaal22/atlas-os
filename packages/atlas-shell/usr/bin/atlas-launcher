#!/bin/sh
# Open the Atlas launcher page in the default browser.
set -e
URL="${ATLAS_COMMAND_CENTRE_URL:-http://127.0.0.1:8787/}"
PLACEHOLDER="/usr/share/atlas/launcher/index.html"

# Prefer live Command Centre when listening; otherwise show placeholder.
if command -v curl >/dev/null 2>&1; then
  if curl -fsS --max-time 1 "$URL" >/dev/null 2>&1; then
    TARGET="$URL"
  else
    TARGET="file://${PLACEHOLDER}"
  fi
else
  TARGET="file://${PLACEHOLDER}"
fi

if command -v xdg-open >/dev/null 2>&1; then
  exec xdg-open "$TARGET"
elif command -v firefox >/dev/null 2>&1; then
  exec firefox --new-window "$TARGET"
else
  echo "Atlas launcher target: $TARGET"
  exit 0
fi
