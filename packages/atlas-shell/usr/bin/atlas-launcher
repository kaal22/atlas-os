#!/usr/bin/env python3
"""Atlas launcher: open local status UI (installed system only)."""
from __future__ import annotations

import json
import os
import socket
import subprocess
import sys
import threading
import time
import traceback
import webbrowser
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from shutil import which

HOST = "127.0.0.1"
PORT = 8791
LOG = Path("/tmp/atlas-launcher.log")
PLACEHOLDER = Path("/usr/share/atlas/launcher/index.html")
LOGO = Path("/usr/share/atlas/launcher/logo.png")
if not LOGO.exists():
    LOGO = Path("/usr/share/atlas/branding/logo.png")


def _load_atlas_conf() -> dict[str, str]:
    conf: dict[str, str] = {}
    path = Path("/etc/atlas/atlas.conf")
    if not path.exists():
        return conf
    try:
        for line in path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            k, v = line.split("=", 1)
            conf[k.strip()] = v.strip().strip('"').strip("'")
    except OSError:
        pass
    return conf


_CONF = _load_atlas_conf()
CC_URL = os.environ.get(
    "ATLAS_COMMAND_CENTRE_URL",
    _CONF.get("ATLAS_COMMAND_CENTRE_URL", "http://127.0.0.1/"),
)


def log(msg: str) -> None:
    try:
        with LOG.open("a", encoding="utf-8") as f:
            f.write(msg.rstrip() + "\n")
    except OSError:
        pass


def is_live_session() -> bool:
    try:
        cmdline = Path("/proc/cmdline").read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return False
    return "boot=live" in cmdline.split()


def open_url(url: str) -> None:
    if which("xdg-open"):
        subprocess.Popen(
            ["xdg-open", url],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
        return
    if which("firefox"):
        subprocess.Popen(
            ["firefox", "--new-window", url],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
        return
    webbrowser.open(url)


def health() -> dict:
    try:
        out = subprocess.check_output(["/usr/bin/atlas-health"], text=True, timeout=8)
        data = json.loads(out)
        if isinstance(data, list):
            return {"firstboot": "unknown", "message": "", "progress": "", "services": data}
        return data
    except Exception as e:
        return {
            "firstboot": "error",
            "message": str(e),
            "progress": "",
            "services": [
                {"name": n, "url": u, "ok": False, "http": 0}
                for n, u in [
                    ("kiwix", "http://127.0.0.1:8080/"),
                    ("qdrant", "http://127.0.0.1:6333/readyz"),
                    ("nomad", "http://127.0.0.1:8090/api/health"),
                    ("ollama", "http://127.0.0.1:11434/api/tags"),
                ]
            ],
        }


def progress_tail() -> str:
    p = Path("/srv/atlas/logs/firstboot-progress.txt")
    if not p.exists():
        return ""
    try:
        lines = p.read_text(encoding="utf-8", errors="replace").splitlines()
        return "\n".join(lines[-12:])
    except Exception:
        return ""


def render_page() -> bytes:
    data = health()
    tail = progress_tail()
    state = data.get("firstboot", "unknown")
    msg = data.get("message") or data.get("progress") or ""
    rows = []
    for item in data.get("services") or []:
        pill = "ok" if item.get("ok") else ("wait" if state == "importing" else "bad")
        label = "wait" if pill == "wait" else ("ok" if item.get("ok") else "bad")
        rows.append(
            f'<div class="row"><span class="name">{item.get("name")}</span>'
            f'<span class="addr">{str(item.get("url","")).replace("http://","")}</span>'
            f'<span class="pill {pill}">{label}</span></div>'
        )
    hint = (
        "First-boot is importing Docker images. This often takes 10–30 minutes on a VM. "
        "This page refreshes every 10 seconds."
        if state == "importing"
        else "Probes bind to 127.0.0.1 only."
    )
    pre = f"<pre class='prog'>{tail}</pre>" if tail else ""
    cc_block = (
        f'<p class="note"><a class="cc" href="{CC_URL}">Open Command Centre →</a></p>'
        if CC_URL
        else ""
    )
    html = f"""<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta http-equiv="refresh" content="10"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Atlas OS</title>
<style>
:root{{--text:#f2f2f2;--muted:#8a8a8a;--ok:#6bcf8e;--bad:#d66;--wait:#c9a227}}
*{{box-sizing:border-box}}body{{margin:0;min-height:100vh;font-family:"Segoe UI","Source Sans 3",system-ui,sans-serif;
color:var(--text);background:radial-gradient(ellipse 80% 50% at 50% -10%,rgba(255,255,255,.08),transparent 55%),#000;
display:grid;place-items:center;padding:2rem}}
main{{max-width:36rem;width:100%;text-align:center}}
img.mark{{width:120px;height:120px;object-fit:contain;margin-bottom:1rem;filter:drop-shadow(0 0 18px rgba(255,255,255,.35))}}
.brand{{font-size:clamp(2rem,6vw,3rem);font-weight:700;letter-spacing:.12em;margin:0 0 .75rem;text-transform:uppercase}}
p{{color:var(--muted);line-height:1.55}}
.status{{margin-top:1.5rem;padding:1rem 1.25rem;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.03);text-align:left}}
.status h2{{margin:0 0 .75rem;font-size:.8rem;letter-spacing:.14em;text-transform:uppercase}}
.row{{display:flex;justify-content:space-between;align-items:center;padding:.4rem 0;border-top:1px solid rgba(255,255,255,.08);font-size:.95rem;gap:.5rem}}
.row:first-of-type{{border-top:0}}.addr{{color:var(--muted);font-family:ui-monospace,monospace;font-size:.8rem}}
.pill{{font-size:.75rem;letter-spacing:.06em;text-transform:uppercase;min-width:3.5rem;text-align:right}}
.pill.ok{{color:var(--ok)}}.pill.bad{{color:var(--bad)}}.pill.wait{{color:var(--wait)}}
.note{{margin-top:.85rem;font-size:.85rem;color:var(--muted)}}
a.cc{{color:#fff;text-decoration:underline}}
.prog{{margin-top:.75rem;max-height:12rem;overflow:auto;background:#0a0a0a;padding:.75rem;font:0.75rem/1.4 ui-monospace,monospace;color:#ccc;white-space:pre-wrap}}
</style></head><body>
<main>
<img class="mark" src="/logo.png" alt="Atlas"/>
<h1 class="brand">Atlas OS</h1>
<p>Private offline AI and knowledge environment.</p>
{cc_block}
<div class="status">
<h2>Local services</h2>
<p class="note" style="margin-top:0">First-boot: <strong>{state}</strong> — {msg}</p>
{''.join(rows)}
{pre}
<p class="note">{hint}</p>
</div>
</main></body></html>"""
    return html.encode("utf-8")


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):  # noqa: N802
        if self.path.startswith("/logo"):
            if LOGO.exists():
                body = LOGO.read_bytes()
                self.send_response(200)
                self.send_header("Content-Type", "image/png")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
                return
            self.send_error(404)
            return
        if self.path.startswith("/api/health"):
            body = json.dumps(health()).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        body = render_page()
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, fmt, *args):  # noqa: A003
        return


def cc_up() -> bool:
    try:
        r = subprocess.run(
            ["curl", "-sS", "-o", "/dev/null", "-w", "%{http_code}", "--max-time", "1", CC_URL],
            capture_output=True,
            text=True,
            check=False,
        )
        code = "".join(c for c in (r.stdout or "") if c.isdigit())
        return bool(code) and code != "000"
    except Exception:
        return False


def port_free(port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            s.bind((HOST, port))
            return True
        except OSError:
            return False


def open_static_fallback() -> None:
    if PLACEHOLDER.exists():
        open_url(PLACEHOLDER.as_uri())
        return
    tmp = Path("/tmp/atlas-status.html")
    tmp.write_text(
        "<html><body style='background:#000;color:#fff;font-family:sans-serif;padding:2rem'>"
        "<h1>Atlas OS</h1><p>Status page missing. Run <code>atlas-health</code> in a terminal.</p>"
        f"<pre>{LOG}</pre></body></html>",
        encoding="utf-8",
    )
    open_url(tmp.as_uri())


def serve_forever() -> None:
    """Long-running status server for systemd (atlas-status.service)."""
    url = f"http://{HOST}:{PORT}/"
    if not port_free(PORT):
        log(f"serve: port {PORT} already in use — exiting (another server owns it)")
        # Another process is serving; stay out of the way
        sys.exit(0)
    server = ThreadingHTTPServer((HOST, PORT), Handler)
    log(f"serve forever {url}")
    print(f"Atlas status on {url}", flush=True)
    server.serve_forever()


def ensure_status_server() -> bool:
    """Start background status server if port free. Return True if something serves :8791."""
    if not port_free(PORT):
        return True
    try:
        server = ThreadingHTTPServer((HOST, PORT), Handler)
    except OSError as e:
        log(f"server bind failed: {e}")
        return False
    threading.Thread(target=server.serve_forever, daemon=True).start()
    time.sleep(0.2)
    log(f"serving http://{HOST}:{PORT}/")
    return True


def main() -> None:
    log(f"start pid={os.getpid()} argv={sys.argv}")
    if is_live_session():
        log("live session — no-op")
        print("Atlas launcher: live session — use Install Atlas OS", flush=True)
        return

    if "--serve" in sys.argv:
        serve_forever()
        return

    url = f"http://{HOST}:{PORT}/"
    # Always prefer the service status page (Kiwix/NOMAD/Ollama). Command Centre is linked from it.
    # Previous behaviour skipped :8791 entirely once CC was up — that broke the status page.
    if not ensure_status_server():
        open_static_fallback()
        if cc_up():
            open_url(CC_URL)
        return

    open_url(url)
    log(f"opened status {url}; cc_up={cc_up()}")

    # Keep process alive so a desktop-launched server does not die immediately
    # (systemd atlas-status.service owns long-lived mode via --serve).
    deadline = time.time() + 2 * 3600
    while time.time() < deadline:
        time.sleep(30)
    log("exit")


if __name__ == "__main__":
    try:
        main()
    except Exception:
        log(traceback.format_exc())
        try:
            open_static_fallback()
        except Exception:
            pass
        sys.exit(1)
